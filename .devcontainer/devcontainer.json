{
  "name": "X-Telegram-Verifier",
  "build": { "dockerfile": "Dockerfile", "context": ".." },
  "workspaceFolder": "/workspace",
  "workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind,consistency=cached",

  // noVNC: open http://localhost:6080/vnc.html to do the one-time X login.
  "forwardPorts": [6080],
  "portsAttributes": {
    "6080": { "label": "noVNC (browser login)", "onAutoForward": "notify" }
  },

  // --- AUTH for Claude Code (the AI runs inside the container) ---
  // Your Claude login persists in this named volume — fully cross-platform
  // (Windows/Mac/Linux), survives rebuilds. Log in ONCE inside the container:
  //   `claude`  then  /login   (Pro/Max subscription, $0/token)   — or —
  //   set ANTHROPIC_API_KEY (below) for pay-per-token.
  // (Linux/Mac power users who'd rather inherit their HOST login can instead use:
  //   "source=${localEnv:HOME}/.claude,target=/root/.claude,type=bind")
  "mounts": [
    "source=claude-config,target=/root/.claude,type=volume"
  ],
  // If you set ANTHROPIC_API_KEY in your host shell, it's passed straight through.
  "containerEnv": {
    "ANTHROPIC_API_KEY": "${localEnv:ANTHROPIC_API_KEY}",
    "DISPLAY": ":99"
  },

  "customizations": {
    "vscode": {
      "extensions": ["anthropic.claude-code", "ms-python.python"]
    }
  },

  "postStartCommand": "bash scripts/start-display.sh || true",
  "remoteUser": "root"
}
