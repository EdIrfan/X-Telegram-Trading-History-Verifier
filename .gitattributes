# Force LF on all text files so shell scripts run inside the Linux container even
# when cloned on Windows (CRLF would break `#!/usr/bin/env bash` -> "bad interpreter").
* text=auto eol=lf
*.sh   text eol=lf
*.py   text eol=lf
*.json text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
Dockerfile text eol=lf

# Binary assets — never normalize.
*.png binary
*.jpg binary
*.jpeg binary
*.gz  binary
*.session binary
