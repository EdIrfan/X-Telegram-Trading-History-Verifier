# Copy this file to ".env" (same folder) and fill in your values. .env is git-ignored.

# ── Telegram (only needed for Telegram channels) ─────────────────────────────
# Get these free at https://my.telegram.org -> "API development tools".
TG_API_ID=
TG_API_HASH=
TG_PHONE=+10000000000        # your phone in international format (used once to log in)

# ── Claude Code auth (pick ONE; subscription is cheaper) ─────────────────────
# Option A — subscription ($20/$100 Pro/Max): leave this blank and instead let the
#   container mount your host ~/.claude (see .devcontainer/devcontainer.json). $0 per token.
# Option B — API key: paste a key here (or export it in your shell). Pay-per-token.
ANTHROPIC_API_KEY=
